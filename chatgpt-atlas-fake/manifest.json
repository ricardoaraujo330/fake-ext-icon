{
  "manifest_version": 3,
  "name": "ChatGPT Atlas",
  "version": "1.0.1",
  "description": "Atalho local que abre atlas://extensions.",
  "minimum_chrome_version": "109",
  "permissions": [
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ChatGPT Atlas",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
